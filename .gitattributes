# Assets not counted
*.png linguist-vendored
*.jpg linguist-vendored
*.jpeg linguist-vendored
*.svg linguist-vendored
*.webp linguist-vendored

# Generated / lock files
package-lock.json linguist-generated
*.tsbuildinfo linguist-generated

# Do not let styles dominate
frontend/src/styles/*.css linguist-vendored
frontend/src/styles/**/*.css linguist-vendored

# Keep Python and TypeScript visible
backend/**/*.py linguist-detectable=true
frontend/src/**/*.ts linguist-detectable=true
frontend/src/**/*.tsx linguist-detectable=true
frontend/index.html linguist-detectable=true
